# ============================================================
# ENNEX MASTER BACKEND - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

PORT=8000

# Your Ennex frontend URL (no trailing slash)
ALLOWED_ORIGIN=https://your-ennex-app.com

# Strong random strings — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-strong-random-secret
ADMIN_JWT_SECRET=replace-with-different-strong-random-secret
HMAC_SHARED_SECRET=replace-with-another-strong-random-secret

# ---- BACKEND SLOT 1 ----
BACKEND_1_NAME=auth
BACKEND_1_URL=https://your-auth-service.onrender.com
BACKEND_1_KEY=your-auth-service-api-key
BACKEND_1_ROUTES=/api/auth/*

# ---- BACKEND SLOT 2 ----
BACKEND_2_NAME=posts
BACKEND_2_URL=https://your-posts-service.onrender.com
BACKEND_2_KEY=your-posts-service-api-key
BACKEND_2_ROUTES=/api/posts/*

# ---- BACKEND SLOT 3 ----
BACKEND_3_NAME=chat
BACKEND_3_URL=https://your-chat-service.onrender.com
BACKEND_3_KEY=your-chat-service-api-key
BACKEND_3_ROUTES=/api/chat/*

# ---- BACKEND SLOT 4 ----
BACKEND_4_NAME=ai
BACKEND_4_URL=https://your-ai-service.onrender.com
BACKEND_4_KEY=your-ai-service-api-key
BACKEND_4_ROUTES=/api/ai/*

# ---- BACKEND SLOT 5 ----
BACKEND_5_NAME=profile
BACKEND_5_URL=https://your-profile-service.onrender.com
BACKEND_5_KEY=your-profile-service-api-key
BACKEND_5_ROUTES=/api/profile/*

# Add BACKEND_6 through BACKEND_20 as needed
